# Copy this file to .env and fill in paths for your machine.
# .env is ignored by git.

# Anima model files
ANIMA_DIT_MODEL=/path/to/anima-preview3-base.safetensors
ANIMA_QWEN3_MODEL=/path/to/anima_qwen_3_06b_base.safetensors
ANIMA_VAE_MODEL=/path/to/anima_vae.safetensors

# Imported Rokkotsu Goddess training config
ANIMA_ROKKOTSU_DATASET_DIR=/path/to/rokkotsu/images
ANIMA_ROKKOTSU_SOURCE_DIR=/path/to/rokkotsu/source
ANIMA_ROKKOTSU_RESIZED_DIR=/path/to/rokkotsu/resized
ANIMA_ROKKOTSU_CACHE_DIR=/path/to/rokkotsu/cache
ANIMA_ROKKOTSU_OUTPUT_DIR=output/ckpt/rokkotsu_goddess
